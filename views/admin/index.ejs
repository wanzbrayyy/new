<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>admin</title>
  <link href="https://fonts.googleapis.com/css?family=Poppins:200,300,400,600,700,800" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/nucleo-icons.css" />
  <link rel="stylesheet" href="/css/alli.min.css" />
  <link rel="stylesheet" href="/css/icone.css" />
  <link rel="stylesheet" href="/css/black-dashboard.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    :root {
      --brand-logo: url('/images/new-coding-logo.jpg');
    }
    .admin-card {
      background: rgba(17, 23, 35, 0.72);
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 18px;
    }
    .admin-card h4,
    .admin-card h5,
    .admin-card p,
    .admin-card li,
    .admin-card label {
      text-transform: lowercase;
    }
    .admin-entry {
      padding: 16px;
      border-radius: 16px;
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.05);
      margin-bottom: 14px;
    }
    .admin-meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .admin-pill {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(0,242,195,.12);
      color: #00f2c3;
      font-size: 12px;
      text-transform: lowercase;
    }
    .brand-box {
      display: inline-flex;
      align-items: center;
      gap: 12px;
    }
    .brand-box img {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      object-fit: cover;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    }
    .invite-link {
      display: block;
      color: #9fe9d5;
      word-break: break-all;
      margin-top: 6px;
      font-size: 13px;
    }
    .inline-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 12px;
    }
    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 12px 0;
      color: rgba(255,255,255,.75);
      text-transform: lowercase;
    }
  </style>
</head>
<body class="sidebar-mini white-content">
  <div class="wrapper">
    <div class="sidebar" data="red">
      <div class="sidebar-wrapper">
        <div class="logo text-center">
          <a href="/" class="simple-text logo-normal brand-box" style="font-size: large;">
            <img src="/images/new-coding-logo.jpg" alt="New Coding">
            <span>New Coding</span>
          </a>
        </div>
        <ul class="nav">
          <li><a href="/docs"><i class="fal fa-alien-monster"></i><p>Dashboard</p></a></li>
          <li><a href="/pricing"><i class="fi-rr-money"></i><p>Pricing</p></a></li>
          <li><a href="/changelog"><i class="fi-rr-refresh"></i><p>Changelog</p></a></li>
          <hr>
          <li><a href="/downloader"><i class="fa fa-fw fa-download"></i><p>Downloader</p></a></li>
          <li><a href="/searching"><i class="fa fa-fw fa-search"></i><p>Searching</p></a></li>
          <li><a href="/randomimage"><i class="far fa-images"></i><p>Random Images</p></a></li>
          <li><a href="/animanga"><i class="fi-rr-crown"></i><p>AniManga</p></a></li>
          <li><a href="/stalking"><i class="fa fa-fw fa-female"></i><p>Stalking</p></a></li>
          <li><a href="/creator"><i class="fi-rr-magic-wand"></i><p>Creator</p></a></li>
          <li><a href="/entertainment"><i class="fa fa-fw fa-smile"></i><p>Entertainment</p></a></li>
          <li><a href="/primbon"><i class="fa fa-fw fa-user-md"></i><p>Primbon</p></a></li>
          <li><a href="/other"><i class="fa fa-fw fa-random"></i><p>Other</p></a></li>
          <li><a href="/ai"><i class="fa fa-fw fa-robot"></i><p>AI</p></a></li>
          <li><a href="/admin/listuser"><i class="far fa-male"></i><p>List User</p></a></li>
          <li class="active" style="margin-bottom: 8rem !important;"><a href="/admin/index"><i class="far fa-feather"></i><p>Admin</p></a></li>
        </ul>
      </div>
    </div>

    <div class="main-panel">
      <div class="navbar-minimize-fixed" style="opacity: 0;">
        <button class="minimize-sidebar btn btn-link btn-just-icon">
          <i class="tim-icons icon-align-center visible-on-sidebar-regular text-dark"></i>
          <i class="tim-icons icon-bullet-list-67 visible-on-sidebar-mini text-dark"></i>
        </button>
      </div>
      <nav class="navbar navbar-expand-lg navbar-absolute navbar-transparent" style="top: 0px;">
        <div class="container-fluid">
          <div class="navbar-wrapper">
            <div class="navbar-minimize d-inline">
              <button class="minimize-sidebar btn btn-link btn-just-icon">
                <i class="tim-icons icon-align-center visible-on-sidebar-regular"></i>
                <i class="tim-icons icon-bullet-list-67 visible-on-sidebar-mini"></i>
              </button>
            </div>
            <div class="navbar-toggle d-inline">
              <button type="button" class="navbar-toggler">
                <span class="navbar-toggler-bar bar1"></span>
                <span class="navbar-toggler-bar bar2"></span>
                <span class="navbar-toggler-bar bar3"></span>
              </button>
            </div>
            <a class="navbar-brand" href="#">New Coding</a>
          </div>
          <div class="navbar-collapse collapse" id="navigation">
            <ul class="navbar-nav ml-auto text-dark">
              <li class="dropdown nav-item">
                <a href="#" class="dropdown-toggle nav-link" data-toggle="dropdown">
                  <div class="photo"><img src="/images/new-coding-logo.jpg" alt="Profile Photo"></div>
                  <b class="caret d-none d-lg-block d-xl-block"></b>
                  <p class="d-lg-none text-dark"><%= username %></p>
                </a>
                <ul class="dropdown-menu dropdown-navbar dropdown-user">
                  <div class="dropdown-user-scroll scrollbar-outer ">
                    <li>
                      <div class="user-box">
                        <div class="avatar-lg"><img src="/images/new-coding-logo.jpg" alt="image profile" class="avatar-img rounded"></div>
                        <div class="u-text text-dark">
                          <h4><%= username %></h4>
                          <p class="text-dark"><%= email %></p>
                        </div>
                      </div>
                    <li>
                      <div class="dropdown-divider"></div>
                      <a class="dropdown-item text-dark" href="/profile"><i class="far fa-address-card text-success"></i>&nbsp;My Profile</a>
                      <div class="dropdown-divider"></div>
                      <a class="dropdown-item text-dark" href="/users/logout"><i class="far fa-sign-out text-danger"></i>&nbsp;Logout</a>
                    </li>
                  </div>
                </ul>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <div class="content">
        <% if (success_msg && success_msg.length) { %>
          <% success_msg.forEach((msg) => { %>
            <div class="alert alert-success"><%= msg %></div>
          <% }) %>
        <% } %>
        <% if (error_msg && error_msg.length) { %>
          <% error_msg.forEach((msg) => { %>
            <div class="alert alert-danger"><%= msg %></div>
          <% }) %>
        <% } %>

        <div class="row">
          <div class="col-md-4">
            <div class="card admin-card">
              <div class="card-body">
                <h4>premium tools</h4>
                <p class="mb-4">buat tambah premium, hapus premium, atau reset limit.</p>

                <h5 class="mt-3">add premium</h5>
                <form method="POST" action="/premium/add">
                  <label>username</label>
                  <input type="text" class="form-control" name="username" required>
                  <label>expired</label>
                  <input type="text" class="form-control" name="expired" placeholder="30d" required>
                  <label>custom api key</label>
                  <input type="text" class="form-control" name="customKey" required>
                  <label>token</label>
                  <input type="text" class="form-control" name="token" required>
                  <button type="submit" class="btn btn-primary btn-round">add premium</button>
                </form>

                <hr>

                <h5>delete premium</h5>
                <form method="POST" action="/premium/delete">
                  <label>username</label>
                  <input type="text" class="form-control" name="username" required>
                  <label>token</label>
                  <input type="text" class="form-control" name="token" required>
                  <button type="submit" class="btn btn-danger btn-round">delete premium</button>
                </form>

                <hr>

                <h5>reset all limit</h5>
                <form method="POST" action="/premium/resetall">
                  <label>token</label>
                  <input type="text" class="form-control" name="token" required>
                  <button type="submit" class="btn btn-info btn-round">reset all</button>
                </form>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card admin-card">
              <div class="card-body">
                <h4>invite link</h4>
                <p class="mb-4">buat link daftar dengan limit sendiri, custom apikey boleh atau tidak, dan batas pemakai link.</p>

                <form method="POST" action="/admin/invite/add">
                  <label>nama link</label>
                  <input type="text" class="form-control" name="title" placeholder="invite komunitas" required>
                  <label>limit apikey</label>
                  <input type="number" class="form-control" name="limit" min="1" value="500" required>
                  <label>batas pemakai link</label>
                  <input type="number" class="form-control" name="maxUses" min="1" value="1" required>
                  <label>custom apikey</label>
                  <select class="form-control" name="allowCustomKey">
                    <option value="false">tidak</option>
                    <option value="true">boleh</option>
                  </select>
                  <button type="submit" class="btn btn-primary btn-round">buat link</button>
                </form>

                <hr>

                <% if (!invites || invites.length === 0) { %>
                  <p class="mb-0">belum ada invite link.</p>
                <% } %>

                <% if (invites && invites.length > 0) { %>
                  <% invites.forEach((invite) => { %>
                    <div class="admin-entry">
                      <div class="admin-meta">
                        <span class="admin-pill"><%= invite.isActive ? 'aktif' : 'nonaktif' %></span>
                        <span class="admin-pill">limit <%= invite.limit %></span>
                        <span class="admin-pill"><%= invite.allowCustomKey ? 'custom key boleh' : 'custom key mati' %></span>
                        <span class="admin-pill"><%= invite.usedCount %>/<%= invite.maxUses %> user</span>
                      </div>
                      <h5><%= invite.title %></h5>
                      <p class="mb-2">dibuat <%= formatDateTime(invite.createdAt) %></p>
                      <a class="invite-link" href="<%= baseUrl %>/users/register?invite=<%= invite.code %>" target="_blank"><%= baseUrl %>/users/register?invite=<%= invite.code %></a>

                      <div class="inline-actions">
                        <form method="POST" action="/admin/invite/toggle/<%= invite._id %>">
                          <button type="submit" class="btn btn-info btn-round"><%= invite.isActive ? 'nonaktifkan' : 'aktifkan' %></button>
                        </form>
                        <form method="POST" action="/admin/invite/delete/<%= invite._id %>">
                          <button type="submit" class="btn btn-danger btn-round">hapus</button>
                        </form>
                      </div>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card admin-card">
              <div class="card-body">
                <h4>manage changelog</h4>
                <p class="mb-4">isi changelog bisa ditambah, diedit, dan dihapus dari sini.</p>

                <form method="POST" action="/admin/changelog/add">
                  <label>title</label>
                  <input type="text" class="form-control" name="title" required>
                  <label>category</label>
                  <select class="form-control" name="category">
                    <option value="update">update</option>
                    <option value="feature">feature</option>
                    <option value="fix">fix</option>
                    <option value="maintenance">maintenance</option>
                  </select>
                  <label>details</label>
                  <textarea class="form-control" name="details" rows="5" placeholder="satu baris satu poin" required></textarea>
                  <button type="submit" class="btn btn-success btn-round">save changelog</button>
                </form>

                <hr>

                <% if (!entries || entries.length === 0) { %>
                  <p class="mb-0">belum ada data changelog.</p>
                <% } %>

                <% if (entries && entries.length > 0) { %>
                  <% entries.forEach((entry) => { %>
                    <div class="admin-entry">
                      <div class="admin-meta">
                        <span class="admin-pill"><%= entry.category %></span>
                        <span class="admin-pill"><%= formatDateTime(entry.updatedAt) %></span>
                      </div>
                      <h5><%= entry.title %></h5>
                      <ul class="mt-3">
                        <% (entry.details || []).forEach((detail) => { %>
                          <li><%= detail %></li>
                        <% }) %>
                      </ul>

                      <form method="POST" action="/admin/changelog/edit/<%= entry._id %>" class="mt-3">
                        <label>title</label>
                        <input type="text" class="form-control" name="title" value="<%= entry.title %>" required>
                        <label>category</label>
                        <select class="form-control" name="category">
                          <option value="update" <%= entry.category === 'update' ? 'selected' : '' %>>update</option>
                          <option value="feature" <%= entry.category === 'feature' ? 'selected' : '' %>>feature</option>
                          <option value="fix" <%= entry.category === 'fix' ? 'selected' : '' %>>fix</option>
                          <option value="maintenance" <%= entry.category === 'maintenance' ? 'selected' : '' %>>maintenance</option>
                        </select>
                        <label>details</label>
                        <textarea class="form-control" name="details" rows="4" required><%= (entry.details || []).join('\n') %></textarea>
                        <button type="submit" class="btn btn-info btn-round">update</button>
                      </form>

                      <form method="POST" action="/admin/changelog/delete/<%= entry._id %>" class="mt-2">
                        <button type="submit" class="btn btn-danger btn-round">delete</button>
                      </form>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/core/jquery.min.js"></script>
  <script src="/js/core/popper.min.js"></script>
  <script src="/js/core/bootstrap.min.js"></script>
  <script src="/js/plugins/perfect-scrollbar.jquery.min.js"></script>
  <script src="/js/plugins/bootstrap-notify.js"></script>
  <script src="/js/black-dashboard.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>

